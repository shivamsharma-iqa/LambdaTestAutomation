{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Playwright Debug Headed",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "${file}",
        "--project=chromium",
        "--headed",
        "--workers=1"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}